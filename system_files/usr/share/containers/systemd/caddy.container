[Container]
Image=docker.io/caddy.latest
ContainerName=Caddy
AutoUpdate=registry
PublishPort=80:80
PublishPort=443:443

Volume=/mnt/orico_a/containers/Caddy/Caddyfile:/etc/caddy/Caddyfile:ro,Z
Volume=/mnt/orico_a/containers/Caddy/config:/config:Z
Volume=/mnt/orico_a/containers/Caddy/data:/data:Z

#Network=caddy.network

[Service]
Restart=always
SuccessExitStatus=0 143

[Install]
WantedBy=default.target