[Container]
ContainerName=caddy
Image=docker.io/library/caddy:latest
AutoUpdate=registry
#Network=host
PublishPort=80:80
PublishPort=443:443
PublishPort=2019:2019
Network=podman

Volume=/mnt/orico_a/containers/caddy/Caddyfile:/etc/caddy/Caddyfile:ro,Z
Volume=/mnt/orico_a/containers/caddy/config:/config:Z
Volume=/mnt/orico_a/containers/caddy/data:/data:Z

[Service]
Restart=always
SuccessExitStatus=0 143

[Install]
#WantedBy=default.target
WantedBy=multi-user.target
