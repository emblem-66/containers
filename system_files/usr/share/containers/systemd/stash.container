[Unit]
After=tailscale-ip.service
Requires=tailscale-ip.service

[Container]
Image=docker.io/nerethos/stash-jellyfin-ffmpeg:latest
ContainerName=stash
AutoUpdate=registry
EnvironmentFile=/run/tailscale-ip.env
PublishPort=${TS_IP}:9999:9999/tcp

Volume=/mnt/orico_a/containers/stash/config:/root/.stash:Z
Volume=/mnt/orico_a/containers/stash/metadata:/metadata:Z
Volume=/mnt/orico_a/containers/stash/cache:/cache:Z
Volume=/mnt/orico_a/containers/stash/blobs:/blobs:Z
Volume=/mnt/orico_a/containers/stash/generated:/generated:Z

Volume=/mnt/orico_a/media_xxx:/data:ro,Z

[Service]
Restart=always
SuccessExitStatus=0 143

[Install]
WantedBy=multi-user.target
